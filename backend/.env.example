# Backend environment variables
# Copy this file to .env and fill in the values

# ACE Step 1.5 audio (comfy-diffusion): models root and separate component filenames
# ACE_COMFY_MODELS_DIR=/path/to/models
# ACE_COMFY_DIFFUSION_MODEL=ace_step_15_unet.safetensors
# ACE_COMFY_TEXT_ENCODER=ace_step_15_text_encoder.safetensors
# ACE_COMFY_VAE=ace_step_15_vae.safetensors

# Anima image (comfy-diffusion): same or different models root
# ANIMA_COMFY_MODELS_DIR=/path/to/models
# ANIMA_COMFY_UNET=unet.safetensors
# ANIMA_COMFY_CLIP=clip.safetensors
# ANIMA_COMFY_VAE=vae.safetensors

# Wan I2V video (comfy-diffusion): same or different models root
# WAN_COMFY_MODELS_DIR=/path/to/models
# WAN_COMFY_UNET_HIGH=...
# WAN_COMFY_UNET_LOW=...
# WAN_COMFY_CLIP=...
# WAN_COMFY_VAE=...
