# Backend environment variables
# Copy this file to .env and fill in the values

# ACE Step 1.5 audio (comfy-diffusion): models root and separate component filenames
# ACE_COMFY_MODELS_DIR=/path/to/models
# ACE_COMFY_DIFFUSION_MODEL=acestep_v1.5_turbo.safetensors
# ACE_COMFY_TEXT_ENCODER=qwen_0.6b_ace15.safetensors
# Optional second text encoder for dual-encoder setup (DualCLIPLoader).
# When set, both encoders are merged into one CLIP with clip_type="ace".
# ACE_COMFY_TEXT_ENCODER_2=qwen_1.7b_ace15.safetensors
# ACE_COMFY_VAE=ace_1.5_vae.safetensors

# Anima image (comfy-diffusion): same or different models root
# ANIMA_COMFY_MODELS_DIR=/path/to/models
# ANIMA_COMFY_UNET=unet.safetensors
# ANIMA_COMFY_CLIP=clip.safetensors
# ANIMA_COMFY_VAE=vae.safetensors

# Wan I2V video (comfy-diffusion): same or different models root
# WAN_COMFY_MODELS_DIR=/path/to/models
# WAN_COMFY_UNET_HIGH=...
# WAN_COMFY_UNET_LOW=...
# WAN_COMFY_CLIP=...
# WAN_COMFY_VAE=...
